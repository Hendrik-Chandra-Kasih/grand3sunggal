// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id_user   Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  role      String   @db.VarChar(20) // 'admin' | 'tutor' | 'siswa' | 'pemilik'

  siswa     Siswa[]
  tutor     Tutor[]

  @@map("users")
}

model Siswa {
  id_siswa        Int      @id @default(autoincrement())
  id_user         Int
  nama            String   @db.VarChar(50)
  tempat_lahir    String?  @db.VarChar(50)
  tanggal_lahir   DateTime? @db.Date
  jenis_kelamin   String?  @db.VarChar(10)
  kelas           String?  @db.VarChar(20)
  jenis_kelas     String?  @db.VarChar(50) // bisa multi-nilai: 'Bimbel SMP, English Course'
  asal_sekolah    String?  @db.VarChar(50)
  alamat          String?  @db.Text
  tanggal_masuk   DateTime? @db.Date
  nama_ortu       String?  @db.VarChar(50)
  pekerjaan_ortu  String?  @db.VarChar(50)
  no_hp_ortu      String?  @db.VarChar(15)
  pendidikan_ortu String?  @db.VarChar(20)
  spp             BigInt   @default(0)
  status          String   @default("Aktif") @db.VarChar(20) // 'Aktif' | 'Nonaktif'

  user            User     @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  kelas_siswa     KelasSiswa[]
  pembayaran      Pembayaran[]
  absensi_siswa   AbsensiSiswa[]

  @@map("siswa")
}

model Tutor {
  id_tutor          Int      @id @default(autoincrement())
  id_user           Int
  nama_tutor        String   @db.VarChar(50)
  tempat_lahir      String?  @db.VarChar(50)
  tanggal_lahir     DateTime? @db.Date
  jenis_kelamin     String?  @db.Char(1) // 'L' | 'P'
  alamat            String?  @db.Text
  pendidikan        String?  @db.VarChar(50)
  no_hp             String?  @db.VarChar(15)
  tanggal_bergabung DateTime? @db.Date
  status            String   @default("Aktif") @db.VarChar(20) // 'Aktif' | 'Nonaktif'

  user              User     @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  kelas             Kelas[]
  jadwal            Jadwal[]
  absensi_tutor     AbsensiTutor[]
  gaji_tutor        GajiTutor[]

  @@map("tutor")
}

model Kelas {
  id_kelas    Int      @id @default(autoincrement())
  nama_kelas  String   @db.VarChar(50)
  jenjang     String?  @db.VarChar(20) // 'SD' | 'SMP' | 'SMA' | 'Calistung' | 'Mafia'
  id_tutor    Int?

  tutor       Tutor?   @relation(fields: [id_tutor], references: [id_tutor], onDelete: SetNull)
  kelas_siswa KelasSiswa[]
  jadwal      Jadwal[]

  @@map("kelas")
}

model KelasSiswa {
  id_kelas_siswa Int @id @default(autoincrement())
  id_siswa       Int
  id_kelas       Int

  siswa          Siswa @relation(fields: [id_siswa], references: [id_siswa], onDelete: Cascade)
  kelas          Kelas @relation(fields: [id_kelas], references: [id_kelas], onDelete: Cascade)

  @@unique([id_siswa, id_kelas])
  @@map("kelas_siswa")
}

model Jadwal {
  id_jadwal Int      @id @default(autoincrement())
  id_kelas  Int
  id_tutor  Int
  hari      String   @db.VarChar(10) // 'Senin' .. 'Jumat'
  jam       DateTime @db.Time(0)

  kelas     Kelas    @relation(fields: [id_kelas], references: [id_kelas], onDelete: Cascade)
  tutor     Tutor    @relation(fields: [id_tutor], references: [id_tutor], onDelete: Cascade)
  absensi_siswa AbsensiSiswa[]

  @@map("jadwal")
}

model Pembayaran {
  id_pembayaran     Int      @id @default(autoincrement())
  id_siswa          Int
  bulan             String?  @db.VarChar(20) // ex: 'Januari 2026'
  tanggal_bayar     DateTime @db.Date
  jenis_pembayaran  String?  @db.VarChar(20) // 'SPP' | 'Modul' | 'Buku'
  jumlah            BigInt   @default(0)
  metode_pembayaran String?  @db.VarChar(20) // 'Tunai' | 'Transfer'
  diskon            BigInt   @default(0)

  siswa             Siswa    @relation(fields: [id_siswa], references: [id_siswa], onDelete: Cascade)

  @@map("pembayaran")
}

model AbsensiSiswa {
  id_absensi         Int      @id @default(autoincrement())
  id_siswa           Int
  id_jadwal          Int
  tanggal            DateTime @db.Date
  pertemuan          Int      @default(1)
  status             String   @db.VarChar(20) // 'Hadir' | 'Tidak Hadir' | 'Sakit' | 'Izin'
  topik_pembelajaran String?  @db.Text

  siswa              Siswa    @relation(fields: [id_siswa], references: [id_siswa], onDelete: Cascade)
  jadwal             Jadwal   @relation(fields: [id_jadwal], references: [id_jadwal], onDelete: Cascade)

  @@map("absensi_siswa")
}

model AbsensiTutor {
  id_absensi_tutor Int      @id @default(autoincrement())
  id_tutor         Int
  tanggal          DateTime @db.Date
  status           String   @db.VarChar(10) // 'Hadir' | 'Absen'

  tutor            Tutor    @relation(fields: [id_tutor], references: [id_tutor], onDelete: Cascade)

  @@map("absensi_tutor")
}

model GajiTutor {
  id_gaji         Int      @id @default(autoincrement())
  id_tutor        Int
  periode         String   @db.VarChar(20)
  total_pemasukan BigInt   @default(0)
  potongan        BigInt   @default(0)
  bonus           BigInt   @default(0)
  total_gaji      BigInt   @default(0)

  tutor           Tutor    @relation(fields: [id_tutor], references: [id_tutor], onDelete: Cascade)

  @@map("gaji_tutor")
}